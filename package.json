{
  "name": "supplier-comparison-local-app",
  "version": "1.0.0",
  "description": "Local web app for comparing product quotes and ranking top suppliers.",
  "main": "api/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron electron-main.js",
    "dist": "electron-builder",
    "test": "node --test \"tests\\*.test.js\""
  },
  "engines": {
    "node": "24.x"
  },
  "license": "UNLICENSED",
  "author": "Giáp",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.giap.suppliercomparison",
    "productName": "Phần mềm so sánh giá",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/price_comparison_icon_1779456120319.png",
      "sign": false,
      "signingHashAlgorithms": []
    },
    "asar": false,
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "files": [
      "**/*"
    ]
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.60.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  }
}
